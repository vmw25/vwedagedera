{
  "name": "HugoBlox Codespace",
  "image": "mcr.microsoft.com/devcontainers/go:1.22-bookworm",
  "features": {
    "ghcr.io/devcontainers/features/node:2.1.0": {
      "version": "22",
      "pnpmVersion": "10.14.0"
    },
    "ghcr.io/devcontainers/features/hugo:1.1.3": {
      "version": "0.161.1",
      "extended": true
    }
  },
  "updateContentCommand": "pnpm install --frozen-lockfile --prefer-offline",
  "postCreateCommand": "pnpm --version && hugo version",
  "customizations": {
    "vscode": {
      "extensions": [
        "ownable.ownable"
      ]
    }
  },
  "remoteUser": "vscode",
  "forwardPorts": [
    1313
  ],
  "portsAttributes": {
    "1313": {
      "label": "Hugo Server"
    }
  }
}
