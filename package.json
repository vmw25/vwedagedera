{
  "name": "vidun-wedagedera-portfolio",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.14.0",
  "description": "Vidun Wedagedera's medicine, research and healthtech portfolio",
  "scripts": {
    "dev": "hugo server --disableFastRender",
    "build": "hugo --gc --minify --cleanDestinationDir && pnpm run pagefind",
    "build:production": "hugo --gc --minify --cleanDestinationDir --baseURL https://vmw25.github.io/vwedagedera/ && pnpm run pagefind",
    "pagefind": "pagefind --site public"
  },
  "dependencies": {
    "@tailwindcss/cli": "^4.1.12",
    "@tailwindcss/typography": "^0.5.10",
    "pagefind": "^1.4.0",
    "preact": "^10.27.2",
    "tailwindcss": "^4.1.12"
  }
}
